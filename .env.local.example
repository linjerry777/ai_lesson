# Gumroad（付款）
GUMROAD_PRODUCT_ID=your_gumroad_product_id

# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── 以下為選用（若要串接 Stripe 或 TapPay） ──

# Stripe
STRIPE_SECRET_KEY=sk_live_...
